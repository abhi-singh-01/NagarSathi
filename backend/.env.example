NODE_ENV=development
PORT=3000

# MongoDB Atlas (cloud) — paste your connection string from Atlas → Connect → Drivers
# Format:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nagarsathi?retryWrites=true&w=majority
#
# Tips:
# - Replace <password> with your DB user password (URL-encode special chars like @ # %)
# - Database name "nagarsathi" is created automatically on first write
# - In Atlas: Network Access → allow your IP (or 0.0.0.0/0 for dev only)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/nagarsathi?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Public base URL for photo links (use your LAN IP for Expo Go on device)
# Example: http://192.168.1.33:3000
BASE_URL=http://localhost:3000

# CORS — comma-separated origins, or * for development
CORS_ORIGIN=*

# Upload limits
MAX_FILE_SIZE_MB=5
