{
  "expo": {
    "name": "NagarSathi",
    "slug": "NagarSathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nagarsathi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.nagarsathi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NagarSathi needs camera access to photograph civic issues.",
        "NSPhotoLibraryUsageDescription": "NagarSathi needs photo library access to attach complaint images.",
        "NSLocationWhenInUseUsageDescription": "NagarSathi needs your location to pin complaints on the map accurately."
      }
    },
    "android": {
      "package": "in.nagarsathi.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F766E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F766E"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NagarSathi to access your photos to attach civic complaint images.",
          "cameraPermission": "Allow NagarSathi to use your camera to capture civic complaint photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NagarSathi to use your location to report issues precisely on the map.",
          "locationWhenInUsePermission": "Allow NagarSathi to use your location while reporting civic complaints.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    }
  }
}
